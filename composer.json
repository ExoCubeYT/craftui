{
    "name": "exocubeyt/craftui",
    "description": "Minecraft-styled components for Laravel Livewire",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "exocubeyt",
            "email": "dev@exocubeyt.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "livewire/livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Exocubeyt\\CraftUI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Exocubeyt\\CraftUI\\CraftUIServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
